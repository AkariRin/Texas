# Git
.git/
.github/
.gitignore

# Python 缓存与构建产物
__pycache__/
*.py[codz]
*$py.class
*.so
*.egg-info/
.eggs/
dist/
build/

# 工具缓存
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/

# 前端依赖与构建产物（在容器内重新安装/构建）
frontend/node_modules/
frontend/dist/
node_modules/

# 环境变量与密钥（绝不打入镜像）
.env
.dev.env
*.pem
*.key
*secret*

# 开发工具与 IDE
.idea/
.vscode/
.pre-commit-config.yaml

# AI / 项目工具
.claude/
.serena/
.spec-workflow/

# 文档与杂项（运行时不需要）
misc/
helm/
README.md
CLAUDE.md
LICENSE
compose.yaml

# 其他
celerybeat-schedule
celerybeat.pid
*.rdb
*.aof
*.log
