# ============================================================
#  Texas 开发环境变量（配合 compose.yaml 中间件使用）
# ============================================================

# ---------- NapCat WebSocket ----------
NAPCAT_ACCESS_TOKEN=Texas
NAPCAT_MESSAGE_POST_FORMAT=array
NAPCAT_REPORT_SELF_MESSAGE=false
NAPCAT_HEART_INTERVAL=30000
NAPCAT_RECONNECT_INTERVAL=5000

# ---------- NapCat 资源 ----------
IMAGE_URL_TTL=7200
ENABLE_RKEY_REFRESH=true

# ---------- PostgreSQL ----------
DATABASE_URL=postgresql+asyncpg://texas:texas@localhost:5432/texas
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ---------- Redis - Celery Broker ----------
CELERY_BROKER_URL=redis://localhost:6379/0

# ---------- Redis - 缓存 ----------
CACHE_REDIS_URL=redis://localhost:6379/1
CACHE_DEFAULT_TTL=300

# ---------- Prometheus ----------
METRICS_ENABLED=true

# ---------- 日志 ----------
LOG_LEVEL=INFO
LOG_FORMAT=console

# ---------- 处理器扫描 ----------
HANDLER_SCAN_PACKAGES=["src.handlers"]

# ---------- 前端 ----------
FRONTEND_DIST_DIR=frontend/dist

# ---------- 服务器 ----------
HOST=0.0.0.0
PORT=8000
