# ============================================================
#  Texas 开发环境变量
# ============================================================

# NapCat WebSocket
NAPCAT_ACCESS_TOKEN=Texas
NAPCAT_MESSAGE_POST_FORMAT=array
NAPCAT_REPORT_SELF_MESSAGE=false
NAPCAT_HEART_INTERVAL=30000
NAPCAT_RECONNECT_INTERVAL=5000

# NapCat 资源
IMAGE_URL_TTL=7200
ENABLE_RKEY_REFRESH=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://texas:texas@localhost:5432/texas
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Chat History PostgreSQL
CHAT_DATABASE_URL=postgresql+asyncpg://texas:texas@localhost:5432/chat_history
CHAT_DB_POOL_SIZE=5
CHAT_DB_MAX_OVERFLOW=10

# Redis - Celery Broker
CELERY_BROKER_URL=redis://localhost:6380

# Redis - RedBeat 调度
CELERY_REDBEAT_URL=redis://localhost:6380

# Redis - 缓存
CACHE_REDIS_URL=redis://localhost:6379
CACHE_DEFAULT_TTL=300

# Redis - 持久化存储
PERSISTENT_REDIS_URL=redis://localhost:6380

# Prometheus
METRICS_ENABLED=true

# 日志
LOG_LEVEL=DEBUG
LOG_FORMAT=console

# 处理器扫描
HANDLER_SCAN_PACKAGES=["src.handlers", "src.core.handlers"]
SERVICE_SCAN_PACKAGES=["src.core.services", "src.services"]
TASK_SCAN_PACKAGES=["src.tasks"]

# 前端
FRONTEND_DIST_DIR=frontend/dist

# 服务器
HOST=0.0.0.0
PORT=8000
